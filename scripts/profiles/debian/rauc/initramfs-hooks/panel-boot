#!/bin/sh
# initramfs-tools hook для RAUC immutable boot.
# Добавляет в initramfs kernel-модули, helper-бинарники и panel-init-persist-paths.

set -e

PREREQ=""
prereqs() { echo "$PREREQ"; }
case $1 in
    prereqs)
        prereqs
        exit 0
        ;;
esac

. /usr/share/initramfs-tools/hook-functions

manual_add_modules squashfs
manual_add_modules overlay
manual_add_modules ext4
manual_add_modules vfat

# Storage drivers — фиксируем явно, чтобы не полагаться на autodetect
# в минимальном initramfs (NVMe/SATA/SCSI/eMMC/USB).
for mod in nvme nvme_core sd_mod ahci ata_piix libata mmc_block sdhci_pci sdhci_acpi usb_storage xhci_pci xhci_hcd ehci_pci ehci_hcd uas; do
    manual_add_modules "$mod" || true
done

# helper, читающий /persist и bind-mount'ящий persistent paths в overlay
if [ -x /usr/local/sbin/panel-init-persist-paths ]; then
    copy_exec /usr/local/sbin/panel-init-persist-paths /sbin/panel-init-persist-paths
else
    echo "ERROR: /usr/local/sbin/panel-init-persist-paths отсутствует; панель не загрузится." >&2
    exit 1
fi

# blkid нужен некоторым ветвям debug-логики; не обязателен.
copy_exec /sbin/blkid /sbin/blkid 2>/dev/null || true
