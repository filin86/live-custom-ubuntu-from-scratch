PROFILE_NAME="Debian"

LIVE_BOOT_DIR="live"
LIVE_SQUASHFS_NAME="filesystem.squashfs"
LIVE_KERNEL_NAME="vmlinuz"
LIVE_INITRD_NAME="initrd.img"
