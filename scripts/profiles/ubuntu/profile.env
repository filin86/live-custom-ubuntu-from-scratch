# Ubuntu profile variables.
# Sourced by build.sh (host side) and chroot_build.sh (chroot side).

PROFILE_NAME="Ubuntu"

LIVE_BOOT_DIR="casper"
LIVE_SQUASHFS_NAME="filesystem.squashfs"
LIVE_KERNEL_NAME="vmlinuz"
LIVE_INITRD_NAME="initrd"

VERSION_VAR_NAME="TARGET_UBUNTU_VERSION"
MIRROR_VAR_NAME="TARGET_UBUNTU_MIRROR"

DEFAULT_VERSION="noble"
DEFAULT_MIRROR="https://archive.ubuntu.com/ubuntu/"

DEBOOTSTRAP_COMPONENTS="main,restricted,universe,multiverse"

KERNEL_PKG_DEFAULT="linux-generic"

DOCKER_APT_DISTRO="ubuntu"

ARCHIVE_KEYRING_PKG="ubuntu-keyring"
